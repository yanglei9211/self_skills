# ===== 项目产物 =====
/output/

# SQLite 数据库：各 skill 的本地数据库一律不入库
# - divination/data/divination.db  脚本首次运行自动构建
# - stock-portfolio-copilot/portfolio.db  本地持仓流水
*.db
*.db-journal
*.sqlite
*.sqlite3

# newsboat-news-hub: 抓取结果、生成的卡片
news_cn.json
news_full.json
cards/
*.png
!references/**/*.png

# stock-portfolio-copilot/docs: 个股分析报告 / 持仓退出计划 / 多账户 spec 等
# 含真实持仓 / 个股名 / 止损价等敏感信息，**永远不入库**
stock-portfolio-copilot/docs/
# 仓库根目录 / 任意子目录里 LLM 生成的 docx 产物（持仓分析等）
*.docx
!references/**/*.docx
!**/agents/**/*.docx

# ===== Playwright 浏览器缓存 =====
.playwright/
